# ---- Notion ----
# Internal integration token from https://www.notion.so/my-integrations
# Leave EMPTY to run with built-in mock content (great for first boot).
NOTION_TOKEN=
# The database ID (32 chars, from the database URL).
NOTION_DATABASE_ID=
# Notion API version. 2022-06-28 is the stable default.
NOTION_VERSION=2022-06-28

# ---- Notion property names (match your database columns exactly) ----
PROP_TITLE=title
PROP_SLUG=slug
PROP_STATUS=status
PROP_TYPE=type
PROP_TAGS=tags
PROP_UPDATED=updatedAt
# Row is shown only when status == this value.
STATUS_PUBLIC_VALUE=Public
# type values (your DB uses Post / Paper).
TYPE_POST_VALUE=Post
TYPE_NOTE_VALUE=Paper

# ---- Webhook ----
# Notion sends this on first handshake; paste it here to enable signature checks.
NOTION_WEBHOOK_SECRET=

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
# Cache TTL in seconds (safety net if a webhook is missed).
CACHE_TTL=3600

# ---- Listing ----
# Cards shown per page before pagination kicks in.
PAGE_SIZE=9

# ---- Site ----
SITE_TITLE=waji // devops notes
SITE_DESCRIPTION=Blogs and notes from the homelab.
SITE_AUTHOR=waji

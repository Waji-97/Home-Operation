{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    "schedule:weekly"
  ],
  "timezone": "Asia/Seoul",
  "kubernetes": {
    "managerFilePatterns": ["/kubernetes/apps/.+\\.ya?ml$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Kubespray release pinned in the setup docs (reminder PR; upgrade is manual via Ansible)",
      "managerFilePatterns": ["kubernetes/docs/initial-setup.md"],
      "matchStrings": ["kubespray/kubespray:(?<currentValue>v\\d+\\.\\d+\\.\\d+)"],
      "datasourceTemplate": "docker",
      "depNameTemplate": "quay.io/kubespray/kubespray"
    }
  ],
  "packageRules": [
    {
      "description": "Group minor + patch updates per dependency",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "{{depName}} (non-major)"
    },
    {
      "description": "Label all dependency PRs",
      "matchManagers": ["kustomize", "kubernetes", "helmv3"],
      "addLabels": ["dependencies"]
    },
    {
      "description": "Stay on Helm 3.x — Helm 4 breaks kustomize --enable-helm in CI",
      "matchDepNames": ["helm"],
      "allowedVersions": "<4.0.0"
    }
  ]
}
